{
  "name": "docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "predev": "fumadocs-mdx",
    "dev": "vite dev",
    "build": "fumadocs-mdx && vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "vite preview --port 5174",
    "check": "ultracite check .",
    "fix": "ultracite fix .",
    "clean": "rm -rf .output .turbo dist .source src/routeTree.gen.ts",
    "typecheck": "fumadocs-mdx && tsc --noEmit",
    "types:check": "fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@tanstack/react-router": "^1.170.7",
    "@tanstack/react-start": "^1.168.10",
    "fumadocs-core": "^16.0.3",
    "fumadocs-mdx": "^14.2.2",
    "fumadocs-ui": "^16.0.3",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.6.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rate-limiter-flexible": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@tailwindcss/vite": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "nitro": "^3.0.260311-beta",
    "tailwindcss": "^4.2.0",
    "typescript": "^5",
    "ultracite": "catalog:",
    "vite": "^8.0.0"
  }
