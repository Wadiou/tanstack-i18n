{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "vite": ["../../../../node_modules/vite/dist/node/index.d.ts"]
    },
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vite/client"]
  },
  "include": ["src/**/*", "vite.config.ts", "messages/**/*"],
  "exclude": ["node_modules"]
}
