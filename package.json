{
	"name": "@wadiou/tanstack-i18n-workspace",
	"license": "MIT",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*",
		"examples/*/*/*"
	],
	"scripts": {
		"build": "turbo build --filter @wadiou/tanstack-i18n && turbo build --filter=!@wadiou/tanstack-i18n",
		"dev": "turbo run dev --ui=tui --filter=!example-*",
		"check": "turbo run check",
		"fix": "turbo run fix",
		"typecheck": "turbo typecheck",
		"test": "turbo run test",
		"validate": "turbo run check typecheck test",
		"clean": "turbo clean && rm -rf node_modules .turbo",
		"preflight": "pnpm clean && pnpm install && pnpm build && pnpm validate",
		"prepare": "husky && git config core.hooksPath .husky",
		"commit": "cz",
		"commit:file": "git commit -F .commit/message",
		"docs:dev": "pnpm --dir apps/docs run dev",
		"docs:preview": "pnpm --dir apps/docs run build && pnpm --dir apps/docs run start",
		"version-packages": "changeset version",
		"release-packages": "changeset publish",
		"examples:pin": "node scripts/examples-pin.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@commitlint/cli": "catalog:",
		"@commitlint/config-conventional": "catalog:",
		"@commitlint/cz-commitlint": "catalog:",
		"commitizen": "catalog:",
		"husky": "catalog:",
		"lint-staged": "catalog:",
		"turbo": "^2.9.7",
		"typescript": "^5.9.3"
	},
	"config": {
		"commitizen": {
			"path": "@commitlint/cz-commitlint"
		}
	},
	"lint-staged": {
		"*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --staged"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.5.0"
}
