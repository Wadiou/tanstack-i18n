{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "root": false,
  "extends": [
    "../../biome.jsonc",
    "ultracite/biome/core",
    "ultracite/biome/vitest"
  ],
  "linter": {
    "rules": {
      "performance": {
        "noBarrelFile": "off"
      },
      "complexity": {
        "noStaticOnlyClass": "off"
      }
    }
  }
}
