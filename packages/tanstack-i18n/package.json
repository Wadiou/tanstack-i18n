{
  "name": "@Wadiou/tanstack-i18n",
  "version": "1.0.0",
  "description": "Locale routing, persistence, and TanStack Start/Router adapters for i18n",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wadiou/tanstack-i18n.git"
  },
  "bugs": {
    "url": "https://github.com/Wadiou/tanstack-i18n/issues"
  },
  "homepage": "https://tanstack-i18n.wadiou.dev",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "i18n",
    "internationalization",
    "locale",
    "tanstack",
    "tanstack-router",
    "react-router",
    "solid-router",
    "tanstack-start",
    "react",
    "solid-js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "default": "./dist/adapters/index.js"
    },
    "./react-router": {
      "types": "./dist/react-router/index.d.ts",
      "import": "./dist/react-router/index.js",
      "default": "./dist/react-router/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./solid": {
      "types": "./dist/solid/index.d.ts",
      "import": "./dist/solid/index.js",
      "default": "./dist/solid/index.js"
    },
    "./solid-router": {
      "types": "./dist/solid-router/index.d.ts",
      "import": "./dist/solid-router/index.js",
      "default": "./dist/solid-router/index.js"
    },
    "./react-start": {
      "types": "./dist/react-start/index.d.ts",
      "import": "./dist/react-start/index.js",
      "default": "./dist/react-start/index.js"
    },
    "./solid-start": {
      "types": "./dist/solid-start/index.d.ts",
      "import": "./dist/solid-start/index.js",
      "default": "./dist/solid-start/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.core.json && tsc -p tsconfig.react.json && tsc -p tsconfig.solid.json",
    "dev": "tsc -p tsconfig.core.json --watch",
    "clean": "rm -rf dist tsconfig.*.tsbuildinfo .turbo",
    "check": "ultracite check .",
    "fix": "ultracite fix .",
    "typecheck": "tsc --noEmit -p tsconfig.core.json && tsc --noEmit -p tsconfig.react.json && tsc --noEmit -p tsconfig.solid.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --typecheck"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "@tanstack/react-router": "^1.170.0",
    "solid-js": "^1.9.0",
    "@tanstack/solid-router": "^1.170.0",
    "@tanstack/react-start": "^1.168.0",
    "@tanstack/solid-start": "^1.168.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@tanstack/react-router": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "@tanstack/solid-router": {
      "optional": true
    },
    "@tanstack/react-start": {
      "optional": true
    },
    "@tanstack/solid-start": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@tanstack/react-router": "^1.170.7",
    "@tanstack/solid-router": "^1.170.0",
    "@tanstack/react-start": "^1.168.10",
    "@tanstack/solid-start": "^1.168.10",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.3",
    "ultracite": "catalog:",
    "vitest": "^4.1.9"
  }
}
